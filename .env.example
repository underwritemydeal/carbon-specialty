# =============================================================================
# Carbon Specialty — environment variables
# =============================================================================
# Copy this file to .env.local for development and configure Vercel for prod.

# Public site URL. Used for canonical URLs, sitemap, OG image absolute URLs.
NEXT_PUBLIC_SITE_URL=https://carbonspecialty.com

# =============================================================================
# Multi-tenant intake — sprint C.S.1.6.5
# =============================================================================

# Comma-separated list of tenant ids whose intake agent is live. A tenant
# must be (a) registered in src/lib/tenants/registry.ts AND (b) listed here
# to be servable by /api/chat. Unset → defaults to "carbon-specialty".
# Onboarding a new brokerage = add its config file + add its id here.
ACTIVE_TENANTS=carbon-specialty

# Bearer token for POST /api/admin/tenant-toggle. Any 32+ char random
# string. Generate with: openssl rand -hex 16
# Unset → the admin endpoint rejects every request with 401.
ADMIN_SECRET=e119bc8c9bc169403a2cd23aa60b9e40

# =============================================================================
# Chat — sprint C.S.1.6 (Worker bypassed; direct Anthropic + tool routes)
# =============================================================================

# Anthropic — required for /api/chat. Reuse Covr's key OR provision a separate
# one. Missing key → /api/chat returns 503; chat falls to contact-form mode.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# Realie Property Data API — required for /api/property/enrich's parcel facts.
# Sprint C.S.1.6.8 swapped this in to replace Regrid, which had a ~$500/mo
# self-serve minimum that didn't fit Carbon's early-stage volume. Realie
# free tier is 25 requests/month + $0.15 per overage; sign up at
# https://realie.ai and generate a token under the developer tab. The token
# is sent as a raw value in the Authorization header (no `Bearer ` prefix
# per Realie's spec). Missing token → parcel lookup degrades gracefully
# (sources_failed.includes("realie")) and chat falls through to blind
# asset-type questions per the C.S.1.6.6 enrichment-lead prompt.
REALIE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Maps Platform — required for /api/property/enrich's canonical
# address + lat/lng + Street View URL. Provision via Google Cloud Console
# with the Geocoding API, Places API, and Street View Static API enabled
# on the same project. Missing key → both geocoding and streetview degrade.
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Client-side Places Autocomplete (sprint C.S.1.6.1). Same Google Cloud
# project as GOOGLE_MAPS_API_KEY — usually the same key, exposed to the
# browser. Restrict in Google Cloud Console to:
#   - HTTP referrer carbonspecialty.com/* + *.vercel.app/*
#   - APIs: Maps JavaScript API + Places API only
# Missing → CarbonChat skips autocomplete; the textarea still works.
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Lead persistence — forward-compat Worker endpoint (unused today; defaults
# to /api/lead-fallback which emails via Resend).
# =============================================================================

# When NEXT_PUBLIC_LEADS_ENDPOINT_READY=true, the chat + form POST here first
# and only fall back to Resend on failure. Until that flips true, every
# submission goes straight to Resend.
NEXT_PUBLIC_LEADS_ENDPOINT=https://covr-worker.example.workers.dev/leads/inbound
NEXT_PUBLIC_LEADS_ENDPOINT_READY=false

# PostHog — same project as Covr AI so the funnel spans both products.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend fallback for lead emails when the Worker endpoint isn't ready.
FALLBACK_EMAIL_TO=underwritemydeal@gmail.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# =============================================================================
# Voice — sprint C.S.1.6.2 (Inworld TTS)
# =============================================================================

# Inworld TTS — required for /api/tts (Carbon's spoken replies).
# Value is the already-base64-encoded "<client_id>:<client_secret>" pair
# from the Inworld dashboard; it is sent verbatim as
#   Authorization: Basic <INWORLD_API_KEY>
# Missing key → /api/tts returns 503 NO_KEY. CarbonChat hides the
# "LISTEN →" affordance and skips voice-reply autoplay; the mic button
# and chat itself still work.
INWORLD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx==
